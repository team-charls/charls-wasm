{
  "name": "charls-wasm-dev",
  "private": true,
  "description": "Development workspace for CharLS WebAssembly - High-performance JPEG-LS codec",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "NODE_NO_WARNINGS=1 NODE_OPTIONS=--experimental-vm-modules jest",
    "test:debug": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "eslint README.md npm/README.md",
    "lint:md:fix": "eslint README.md npm/README.md --fix"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/unit/**/*.test.js"
    ],
    "transform": {}
  },
  "standard": {
    "env": [
      "jest"
    ],
    "globals": [
      "fail"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/team-charls/charls-wasm.git"
  },
  "author": "Team CharLS",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/team-charls/charls-wasm/issues"
  },
  "homepage": "https://github.com/team-charls/charls-wasm#readme",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@eslint/markdown": "^6.2.1",
    "eslint": "^9.17.0",
    "glob": "^13.0.6",
    "globals": "^15.14.0",
    "jest": "^30.3.0",
    "rimraf": "^6.1.3"
  }
}
